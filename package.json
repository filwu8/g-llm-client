{
  "name": "g-llm-client",
  "version": "1.2.2",
  "description": "WujiJie / G-LLM desktop client",
  "main": "./out/main/index.js",
  "author": "GPROPHET LIMITED <licensing@gprophet.com>",
  "license": "BUSL-1.1",
  "homepage": "https://llm.gprophet.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/filwu8/g-llm-client.git"
  },
  "desktopName": "G-LLM",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm i18n:check && pnpm licenses:generate && tsc --noEmit && electron-vite build",
    "i18n:check": "node scripts/check-translations.mjs",
    "licenses:generate": "node scripts/generate-third-party-notices.mjs",
    "preview": "electron-vite preview",
    "package:win": "pnpm build && electron-builder --win --x64 --publish never",
    "package:mac": "pnpm build && electron-builder --mac --arm64 --x64 --publish never",
    "package:linux": "pnpm build && electron-builder --linux --x64 --publish never"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@napi-rs/canvas": "0.1.80",
    "electron-store": "^10.1.0",
    "i18next": "^26.3.6",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.16.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "17.0.9",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "optionalDependencies": {
    "@napi-rs/canvas-darwin-arm64": "0.1.80",
    "@napi-rs/canvas-darwin-x64": "0.1.80",
    "@napi-rs/canvas-linux-x64-gnu": "0.1.80",
    "@napi-rs/canvas-win32-x64-msvc": "0.1.80"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.gllm.wujijie",
    "productName": "G-LLM",
    "directories": {
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "resources/app-icon.png",
        "to": "resources/app-icon.png"
      },
      {
        "from": "resources/tray-icon-template.png",
        "to": "resources/tray-icon-template.png"
      },
      {
        "from": "resources/tray-icon.png",
        "to": "resources/tray-icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "resources/icon.ico"
      },
      {
        "from": "resources/workspace-script-runner.cjs",
        "to": "resources/workspace-script-runner.cjs"
      },
      {
        "from": "LICENSE",
        "to": "legal/LICENSE.txt"
      },
      {
        "from": "NOTICE",
        "to": "legal/NOTICE.txt"
      },
      {
        "from": "LICENSE_POLICY.md",
        "to": "legal/LICENSE_POLICY.md"
      },
      {
        "from": "COMMERCIAL_LICENSE.md",
        "to": "legal/COMMERCIAL_LICENSE.md"
      },
      {
        "from": "TRADEMARKS.md",
        "to": "legal/TRADEMARKS.md"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "legal/THIRD_PARTY_NOTICES.md"
      }
    ],
    "files": [
      "out/**/*"
    ],
    "artifactName": "G-LLM-Setup-${version}-${arch}.${ext}",
    "win": {
      "icon": "build/icon.ico",
      "executableName": "G-LLM",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "include": "build/installer.nsh",
      "displayLanguageSelector": true,
      "installerLanguages": [
        "en_US",
        "zh_CN"
      ],
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "menuCategory": "GProphet",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "G-LLM",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "identity": "-",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Utility",
      "syncDesktopName": true,
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
